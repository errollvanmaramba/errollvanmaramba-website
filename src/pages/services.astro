---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageShell from "../components/layout/PageShell.astro";
import SectionShell from "../components/layout/SectionShell.astro";
import Button from "../components/ui/Button.astro";
import { services } from "../content/services";
---
<BaseLayout title="Services — Erroll Van Maramba" description="Creative marketing design services by Erroll Van Maramba for eCommerce brands and growth-focused teams.">
  <PageShell
    eyebrow="Services"
    title="Freelance services framed for practical client decisions."
    summary="This page keeps the offer clear, structured, and easy to scan so the site supports inquiry-driven conversion rather than generic portfolio browsing."
  />

  <SectionShell
    eyebrow="Offer"
    title="Focused creative support for eCommerce and marketing teams."
    copy="Each service area is written to be expanded later with deliverables, sample outcomes, and a more refined conversion flow."
  >
    <div class="card-grid cols-2">
      {services.map((service) => (
        <article class="card stack-md">
          <h2>{service.title}</h2>
          <p class="text-muted">{service.summary}</p>
          <ul class="service-list" role="list">
            {service.deliverables.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div style="height: var(--space-xl);"></div>

    <Button href="/contact">Work with me</Button>
  </SectionShell>
</BaseLayout>
