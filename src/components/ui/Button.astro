---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  target?: "_blank" | "_self";
  rel?: string;
}

const { href, variant = "primary", target = "_self", rel } = Astro.props;
---
<a class:list={["button", variant === "primary" ? "button--primary" : "button--secondary"]} href={href} target={target} rel={rel}>
  <slot />
</a>
