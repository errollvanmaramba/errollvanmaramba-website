---
import SectionShell from "../layout/SectionShell.astro";
import { services } from "../../content/services";
---
<SectionShell
  eyebrow="03 / Services"
  title="Freelance design support shaped for eCommerce brands and modern marketing teams."
  copy="The service layer is intentionally clear and conversion-friendly so clients can understand your offer without reading a long biography first."
  divider={true}
>
  <div class="card-grid cols-2">
    {services.map((service) => (
      <article class="card stack-md">
        <h3>{service.title}</h3>
        <p class="text-muted">{service.summary}</p>
        <ul class="service-list" role="list">
          {service.deliverables.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</SectionShell>
