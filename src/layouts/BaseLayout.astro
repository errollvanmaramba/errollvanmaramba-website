---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/content';
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
}

const props = Astro.props;
const site = getSiteSettings();
const title = props.title ? `${props.title} | ${site.name}` : site.seo.title;
const description = props.description ?? site.seo.description;
const imagePath = props.image ?? '/social/og-default.svg';
const image = imagePath.startsWith('http') ? imagePath : `${new URL(withBase(imagePath), Astro.site).toString()}`;
const canonical = new URL(props.canonicalPath ?? Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e1420" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@500;700;800&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main id="content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
